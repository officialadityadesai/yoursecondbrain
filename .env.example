# Required: get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Rollout profile for retrieval behavior.
# safe = lower latency/cost, balanced = default, aggressive = deeper retrieval.
MSB_ROLLOUT_MODE=balanced

# Optional: if you expose the backend on a different host, set this so links are correct.
# MSB_PUBLIC_BASE_URL=http://127.0.0.1:8000

# Optional: override the frontend URL used for node view links (auto-discovered if not set).
# MSB_FRONTEND_URL=http://localhost:5173

# Optional MCP server tuning.
# MSB_BACKEND_TIMEOUT_SECONDS=90
# MSB_FALLBACK_GUARD_SECONDS=45
# MSB_STRICT_FALLBACK_REQUIRES_HOLISTIC=1

# Optional retrieval tuning (advanced).
# MCP_SIDECAR_TTL_SECONDS=420
# MCP_HOLISTIC_CANDIDATE_FILES=260
# MCP_HOLISTIC_CANDIDATE_ROWS=7000
# MCP_HOLISTIC_EVIDENCE_FILES=9
